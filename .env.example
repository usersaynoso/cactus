# =============================================================================
# Cactus — Environment Variables Reference
# Copy this file to .env.local for local development.
# NEVER commit .env or .env.local to git.
# =============================================================================

# =============================================================================
# REQUIRED — setup cannot proceed without these
# =============================================================================

# PostgreSQL connection string. Use a pooled URL (Neon, Supabase, PgBouncer).
# Example: postgres://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=

# Secret for signing session tokens. Min 32 random characters.
# Generate: openssl rand -base64 32
SESSION_SECRET=

# The canonical public domain of this site. Used to derive the WebAuthn
# relying party ID. Cannot be changed after first passkey is registered.
# Example: https://example.com
SITE_URL=

# Public-facing version of SITE_URL (must match SITE_URL). Shown in the
# browser-side setup wizard so the admin can verify the domain is correct.
# Example: https://example.com
NEXT_PUBLIC_SITE_URL=

# =============================================================================
# OPTIONAL — setup proceeds without these; the relevant feature is disabled
# until the variable is set and the app is redeployed.
# =============================================================================

# --- Email (gates password+email-OTP login, email verification, recovery) ---
# Provide either Brevo OR SMTP credentials; Brevo takes priority if both set.

BREVO_API_KEY=
# --- OR ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Media (gates all image upload, including logo/favicon) ---
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_ENDPOINT=
# Full URL of the Cloudflare Worker that proxies B2 objects
CLOUDFLARE_WORKER_URL=
# Just the hostname part, used in next.config.ts remotePatterns
CLOUDFLARE_WORKER_HOSTNAME=

# --- GitHub API (gates module/theme install and update) ---
# Needs repo-read scope for release checks; repo-write for installs/updates.
GITHUB_API_TOKEN=
# Your Cactus main repo (owner/repo format), e.g. "myorg/my-cactus-site"
# Required for committing module/theme submodules via the GitHub API.
GITHUB_REPO=

# --- Vercel API (gates Edge Config writes and deployment status checks) ---
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
# Edge Config read connection string (format: ecfg_xxxx)
EDGE_CONFIG=
# The Edge Config's own numeric ID
VERCEL_EDGE_CONFIG_ID=
# Vercel webhook secret for deployment events (Pro/Enterprise only)
# If not set, status is checked lazily on next Modules/Themes page load
VERCEL_WEBHOOK_SECRET=

# --- Cloudflare Turnstile (gates bot protection on public forms) ---
# Without these, forms rely on rate limiting only
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Error reporting ---
SENTRY_DSN=

# --- Runtime environment (set automatically by Next.js) ---
# NODE_ENV=development
